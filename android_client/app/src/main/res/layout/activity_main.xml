<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="20dp"
            android:paddingEnd="16dp"
            android:paddingBottom="104dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_sync"
            android:textColor="@color/ios_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/subtitle_sync"
            android:textColor="@color/ios_text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/ios_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/ios_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_connection"
                    android:textColor="@color/ios_text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/hostEditText"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input_box"
                    android:hint="@string/hint_host"
                    android:inputType="textNoSuggestions"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/ios_text_primary"
                    android:textColorHint="@color/ios_text_secondary" />

                <EditText
                    android:id="@+id/portEditText"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input_box"
                    android:hint="@string/hint_port"
                    android:inputType="number"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="8765"
                    android:textColor="@color/ios_text_primary"
                    android:textColorHint="@color/ios_text_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/connectButton"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:minHeight="50dp"
                    android:text="@string/connect"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/ios_accent"
                    app:cornerRadius="25dp"
                    app:elevation="0dp"
                    app:rippleColor="#33FFFFFF" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/statusTextView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_neutral"
                        android:paddingStart="10dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="8dp"
                        android:text="Disconnected"
                        android:textColor="@color/ios_text_primary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/latencyTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chip_success"
                        android:paddingStart="10dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="8dp"
                        android:text="RTT: -"
                        android:textColor="@color/ios_text_primary"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/ackTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_chip_neutral"
                    android:paddingStart="10dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="8dp"
                    android:text="ACK: -"
                    android:textColor="@color/ios_text_primary"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/label_paste_mode"
                    android:textColor="@color/ios_text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/pasteModeRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/pasteModeCtrlVRadioButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/ios_accent"
                        android:checked="true"
                        android:text="@string/paste_mode_ctrl_v"
                        android:textColor="@color/ios_text_primary" />

                    <RadioButton
                        android:id="@+id/pasteModeCtrlShiftVRadioButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/ios_accent"
                        android:text="@string/paste_mode_ctrl_shift_v"
                        android:textColor="@color/ios_text_primary" />

                    <RadioButton
                        android:id="@+id/pasteModeShiftInsertRadioButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/ios_accent"
                        android:text="@string/paste_mode_shift_insert"
                        android:textColor="@color/ios_text_primary" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/ios_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/ios_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_input"
                    android:textColor="@color/ios_text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/inputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input_box"
                    android:gravity="top|start"
                    android:hint="@string/hint_input"
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:padding="14dp"
                    android:textColor="@color/ios_text_primary"
                    android:textColorHint="@color/ios_text_secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/clearReconnectButton"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="18dp"
        android:minHeight="56dp"
        android:text="@string/clear_input"
        android:textAllCaps="false"
        android:textColor="@color/ios_accent"
        app:backgroundTint="@color/ios_accent_soft"
        app:cornerRadius="28dp"
        app:elevation="0dp"
        app:rippleColor="#332D7FF9" />
</FrameLayout>
